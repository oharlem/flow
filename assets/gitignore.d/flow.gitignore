# Flow — appended to your project's .gitignore by /flow-setup

# Per-change drift report cache (written by /flow-test; not committed)
**/.flow-test.last.md

# Per-change build queue state (written by /flow-build prepare, cleared at
# finalize/close; only a run interrupted between the two leaves a stale copy)
**/.flow/build-pending.yaml

# Flow's internal cache directory
.flow/.cache/

# Embedded default assets are served from the running binary; on-disk copies
# are version-coupled to a previous binary and should not be committed.
# Local overrides under .flow/agents/*.local.md are still tracked.
.flow/conventions/
.flow/agents/*.base.md

# Contributor-only live runtime link; user projects commit .flow/runtime instead.
.flow/local.runtime

# Integration test temp repos
tests/integration/scenarios/.tmp-*/

# Common Python bytecode generated by Flow-built Python apps and tests
__pycache__/
*.pyc

# Host-specific cache directories
# Claude Code
.claude/.cache/
# Codex CLI
.codex/.cache/
# Cursor
.cursor/.cache/

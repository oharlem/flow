# .flow/config.yaml
# Flow project configuration — generated by /flow-setup.
# Edit freely; `flow update` may add missing default keys and refresh `hosts`
# from installed Flow host assets while preserving existing non-host values.
#
# Config-Schema-Version: 1.0

schema_version: 1.0

# Project policy for phase save prompts. Default `no` lets Flow phase agents
# run printed state-save commands directly after writing artifacts.
confirmation: "no"

layout:
  # Installed artifact layout. Version 2 keeps `.flow/` as the runtime control
  # plane and places human-facing artifacts under `<prefix>/`.
  version: 2

# Visible Flow artifact root and git branch namespace.
# With prefix: flow, work artifacts live under flow/runs/ and branches are flow/<name>.
prefix: flow

# Hosts this project is wired for. A repo can be wired for one or several
# hosts (Claude Code, Codex, Cursor) simultaneously; each gets its
# own command/skill files. Allowed entries: claude-code | codex | cursor.
hosts:
  - claude-code

git:
  # Branches where Flow warns and prompts before running (not hard-refused).
  # Glob patterns supported (e.g., "release/*").
  # Set FLOW_FORCE_ON_PROTECTED=1 in the environment to skip the prompt.
  protected_branches:
    - main
    - master
    - trunk
    - develop
    - "release/*"

  # Set to true to create each change in a sibling git worktree instead of
  # switching branches. Useful when working on multiple changes simultaneously.
  worktrees: false

  # When true, `flow run` creates a local run branch at run creation.
  run_branch: true

  # When true, roadmap-scoped runs create local checkpoint commits after each
  # milestone closes successfully. Flow still never pushes, pulls, fetches,
  # tags, force-resets, or calls GitHub/GitLab CLIs.
  run_checkpoint_commits: true

  # Local default branch used as the base for `docs.touch_map` diff checks.
  # When absent, Flow tries "main" then "master" automatically.
  # Example: default_branch: develop
  # default_branch: main

# Review-before-finalize behavior (M-24).
#
# `before_finalize: false` (default) uses collapsed review on the green path:
# the printed `Next command: flow X --finalize` footer is suppressed; the
# agent runs the command shown as `**Save state with**` in the envelope
# (which always carries the canonical finalize command for the current
# phase, including dynamic arguments like the active task ID for
# `build-task`). Internal drivers may chain phases (e.g. build → test)
# without a second prepare envelope. Set to `true` to keep the two-stage
# protocol (prepare → footer → finalize as a separate command),
# which is useful when you want to review the printed envelope before each
# state save.
#
# `per_command` overrides `before_finalize` for one Flow subcommand at a
# time using the same boolean semantics. Example: keep two-stage for
# `flow plan` only while every other command collapses on the green path.
#   per_command:
#     plan: true
#
# This setting is orthogonal to `confirmation` above; setting one does not
# change the other. There is no `--review` / `--no-review` CLI flag.
review:
  before_finalize: false
  # per_command: {}

test:
  # Optional test command override. When null, Flow auto-detects safe,
  # well-known project test runners where it can, such as Cargo workspaces.
  # Example: "pnpm test --run" or "cargo test"
  command: null

  # Optional command to run before the test command (e.g., a build step).
  pre_command: null

  # How long Flow waits for the test command before declaring failure (seconds).
  timeout_seconds: 600

preflight:
  # Task-scoped environment checks used by `Requires:` lines in tasks.md.
  # Flow includes a built-in `docker` requirement:
  #   command: "docker info >/dev/null 2>&1"
  #
  # Example project-specific requirement:
  # requirements:
  #   postgres:
  #     description: "Local Postgres is accepting connections"
  #     command: "pg_isready -q"
  #     remediation: "Start Postgres, then rerun the Flow command."
  requirements: {}

# Per-phase reasoning effort and model overrides.
# effort: standard | high
# model: null (host default) or a specific model ID
phases:
  setup: { effort: standard }
  start: { effort: high }
  amend: { effort: high }
  plan:  { effort: high }
  build: { effort: standard }
  check: { effort: standard }
  close: { effort: high }

ui:
  # Voice hint passed to phase agents. One of: friendly | terse | formal
  voice: friendly

  # Set to true to ask agents to avoid non-ASCII characters in their output.
  ascii_only: false

# Docs freshness settings (all keys optional).
# docs:
#   # Optional Flow-maintained documentation corpus path. When absent, layout v2
#   # uses `<prefix>/docs/` for current-state documentation that must be kept
#   # in sync before closing each change.
#   # documentation_path: flow/docs
#
#   # Days before a **Reviewed**: YYYY-MM-DD marker is considered stale.
#   # When absent, Flow checks for marker presence but not age.
#   # review_max_age_days: 180
#
#   # Source-to-doc mappings: when any source glob matches a file in the branch
#   # diff, the listed doc paths are expected to also appear in the diff.
#   # `flow doctor` and release commands emit advisory warnings; nothing is blocked.
#   # touch_map:
#   #   - paths:
#   #       - 'crates/flow-core/src/**'
#   #     docs:
#   #       - 'docs/reference/commands.md'
#   #   - paths:
#   #       - 'assets/templates/**'
#   #     docs:
#   #       - 'docs/reference/artifacts.md'
#   #     suppress: false  # set to true to silence this entry's warnings
#
#   # Set to false to globally suppress all touch-map warnings.
#   # touch_map_warnings: true
